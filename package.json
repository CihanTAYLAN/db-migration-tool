{
  "name": "migration-cli",
  "version": "1.0.0",
  "description": "MySQL to PostgreSQL Migration Tool",
  "main": "dist/cli/index.js",
  "bin": {
    "migration": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "generate": "prisma generate --schema=prisma/schema-mysql.prisma && prisma generate --schema=prisma/schema-postgres.prisma",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "migration",
    "mysql",
    "postgresql",
    "database",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@types/node": "^24.4.0",
    "@types/pg": "^8.15.5",
    "commander": "^14.0.1",
    "mysql2": "^3.14.5",
    "pg": "^8.16.3",
    "prisma": "^6.16.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}