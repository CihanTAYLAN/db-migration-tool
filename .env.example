# Database Migration CLI Configuration
# Copy this file to .env and fill in your actual values

# Source Database Configuration
# Supported types: mysql, postgresql
SOURCE_DB_TYPE=mysql
SOURCE_DATABASE_URL=mysql://username:password@localhost:3306/source_database

# Target Database Configuration
# Supported types: mysql, postgresql
TARGET_DB_TYPE=postgresql
TARGET_DATABASE_URL=postgresql://username:password@localhost:5432/target_database?schema=public

# Logging Configuration
# Available levels: error, warn, info, debug
LOG_LEVEL=info

# Optional: Database Connection Pool Settings
# These are optional and depend on your database type
# SOURCE_DB_POOL_SIZE=10
# TARGET_DB_POOL_SIZE=10

# Optional: Migration Settings
# MIGRATION_BATCH_SIZE=1000
# MIGRATION_TIMEOUT=30000

# Optional: Development Settings
# NODE_ENV=development
